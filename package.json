{
  "name": "budgie",
  "version": "0.9.3",
  "private": true,
  "main": "public/electron.js",
  "description": "A simple home finance app built with Electron and React.",
  "author": "Mark Fairhurst",
  "homepage": "./",
  "scripts": {
    "start": "concurrently \"vite\" \"bun run electron-start\"",
    "build": "electron-rebuild -f -w better-sqlite3 && vite build && vite build --config vite.main.config.ts && bun run electron-build",
    "electron-start": "wait-on http://localhost:3000 && vite build --config vite.main.config.ts && electron .",
    "electron-build": "electron-builder",
    "electron-build:win": "electron-builder --win",
    "test": "npm rebuild better-sqlite3 && vitest run",
    "lint": "eslint --fix",
    "check-types": "tsc --noEmit",
    "format": "prettier --write .",
    "prepare": "husky",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "db:migrate": "drizzle-kit generate",
    "db:seed": "bun run src/main/db/seeds/accounts.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/nunito-sans": "^5.2.7",
    "@tanstack/react-query": "^5.90.21",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "recharts": "2.15.4",
    "rrule": "^2.8.1",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@electron/rebuild": "^4.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@prettier/plugin-oxc": "^0.1.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/eslint": "^9.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "electron": "^40.8.2",
    "electron-builder": "^26.8.2",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-motion": "^1.1.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.markfairhurst.budgie",
    "productName": "Budgie",
    "icon": "public/assets/icon.icns",
    "files": [
      "build/**/*",
      "public/electron.js",
      "public/preload.js",
      "public/db.js",
      "public/ipc/**/*",
      "src/main/db/migrations/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "out"
    },
    "publish": {
      "provider": "github",
      "owner": "airburst",
      "repo": "budgie"
    },
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "deb"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
